{
  "name": "@onecoach/lib-flight",
  "version": "0.1.0",
  "description": "OneFlight - Flight search and deal finding for OneCoach",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "import": "./dist/agents/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./sdk-agents/flight-search/schema": {
      "types": "./src/sdk-agents/flight-search/schema.ts",
      "import": "./src/sdk-agents/flight-search/schema.ts"
    }
  },
  "files": [
    "dist",
    "src/sdk-agents"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit",
    "test:agent": "tsx test-sdk-agent.ts"
  },
  "dependencies": {
    "@giulio-leone/agent-contracts": "workspace:*",
    "ai": "6.0.77",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@onecoach/lib-ai": "workspace:*",
    "@onecoach/lib-shared": "workspace:*",
    "@onecoach/one-agent": "workspace:*",
    "@onecoach/types-core": "workspace:*",
    "@onecoach/types-workout": "workspace:*",
    "@onecoach/types-nutrition": "workspace:*",
    "@onecoach/types-chat": "workspace:*",
    "@onecoach/types-analytics": "workspace:*",
    "@onecoach/types-ai": "workspace:*",
    "@onecoach/types-ui": "workspace:*",
    "@onecoach/types-domain": "workspace:*",
    "@onecoach/types-database": "workspace:*"
  },
  "devDependencies": {
    "@onecoach/contracts": "workspace:*",
    "@onecoach/lib-core": "workspace:*",
    "@onecoach/lib-mcp-server": "workspace:*",
    "@onecoach/lib-validation": "workspace:*",
    "@onecoach/schemas": "workspace:*",
    "@types/node": "^25.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "sideEffects": [
    "./src/sdk-agents/*/schema.ts"
  ]
}
