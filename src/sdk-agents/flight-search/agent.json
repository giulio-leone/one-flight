{
  "id": "flight-search",
  "version": "1.1.0",
  "type": "agent",
  "interface": {
    "input": { "$ref": "./schema.ts#FlightSearchInputSchema" },
    "output": { "$ref": "./schema.ts#FlightSearchOutputSchema" }
  },
  "mcpServers": {
    "kiwi": {
      "url": "https://mcp.kiwi.com"
    }
  },
  "skills": {
    "path": "skills",
    "expose": ["price-analysis", "recommendation"]
  },
  "tools": {
    "source": "mcp",
    "allowlist": ["kiwi_search", "kiwi_book"]
  },
  "progress": {
    "aiDriven": true,
    "fallbackSteps": [
      { "name": "parsing", "weight": 10 },
      { "name": "searching", "weight": 60 },
      { "name": "ranking", "weight": 20 },
      { "name": "formatting", "weight": 10 }
    ]
  },
  "config": {
    "tier": "balanced",
    "temperature": 0.3,
    "maxSteps": 10,
    "maxTokens": 4096,
    "timeout": 60000,
    "executionMode": "durable",
    "durability": {
      "maxDurationMs": 120000,
      "checkpointStrategy": "step"
    }
  }
}
